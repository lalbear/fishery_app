{
    "name": "fishing-god-backend",
    "version": "1.0.0",
    "description": "Backend API for Fishing God Platform",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "db:migrate": "node dist/scripts/migrate.js",
        "db:seed": "node dist/scripts/seed.js",
        "db:seed:knowledge": "node dist/scripts/seed_knowledge.js",
        "lint": "eslint . --ext .ts",
        "test": "jest"
    },
    "dependencies": {
        "@types/node-cron": "^3.0.11",
        "@types/node-fetch": "^2.6.13",
        "@types/uuid": "^10.0.0",
        "axios": "^1.13.6",
        "bcrypt": "^6.0.0",
        "cheerio": "^1.2.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^8.3.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.3",
        "node-cron": "^4.2.1",
        "node-fetch": "^2.7.0",
        "pg": "^8.12.0",
        "redis": "^4.6.14",
        "uuid": "^7.0.3",
        "winston": "^3.13.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/express-rate-limit": "^5.1.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.19.39",
        "@types/pg": "^8.20.0",
        "eslint": "^8.57.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.3",
        "puppeteer": "^24.41.0",
        "ts-jest": "^29.1.4",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
