{
  "expo": {
    "name": "Fishing God",
    "slug": "fishing-god-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "softwareKeyboardLayoutMode": "pan",
    "plugins": [
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Fishing God uses your location to help analyze pond suitability and save pond coordinates."
        }
      ]
    ],
    "experiments": {
      "baseUrl": "/fishery_app"
    },
    "ios": {
      "bundleIdentifier": "com.pranjalupadhyay.fishinggod",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.pranjalupadhyay.fishinggod",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "2d8baa63-8bf9-4d0b-b463-d4f8d56a7a34"
      }
    }
  }
}
