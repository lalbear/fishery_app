{
  "expo": {
    "name": "Fishing God",
    "slug": "fishing-god-mobile",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "softwareKeyboardLayoutMode": "pan",
    "plugins": [
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Fishing God uses your location to help analyze pond suitability and save pond coordinates."
        }
      ]
    ],
    "experiments": {
      "baseUrl": "/fishery_app"
    },
    "ios": {
      "bundleIdentifier": "com.pranjalupadhyay.fishinggod",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.pranjalupadhyay.fishinggod",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c404c"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCKN_McLqLKtxvw55YC4Pwhy8Knhyrc9kM"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "2d8baa63-8bf9-4d0b-b463-d4f8d56a7a34"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2d8baa63-8bf9-4d0b-b463-d4f8d56a7a34"
    }
  }
}
