{
  "name": "fishing-god-platform",
  "version": "1.0.0",
  "description": "Aquaculture Intelligence Platform for the Indian Subcontinent",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:mobile\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:mobile": "cd mobile && npx expo start",
    "build": "npm run build:backend && npm run build:mobile",
    "build:backend": "cd backend && npm run build",
    "build:mobile": "cd mobile && npx expo prebuild",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:seed": "cd backend && npm run db:seed",
    "test": "npm run test --workspace backend -- --passWithNoTests --runInBand && npm run test --workspace mobile -- --passWithNoTests --runInBand",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "npm run typecheck --workspace backend && npm run typecheck --workspace mobile"
  },
  "workspaces": [
    "backend",
    "mobile"
  ],
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "~19.1.10",
    "concurrently": "^8.2.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
